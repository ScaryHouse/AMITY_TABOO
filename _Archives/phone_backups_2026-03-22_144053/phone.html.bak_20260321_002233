<!DOCTYPE html>
<html>
<head>
  <base target="_top">
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <title>AMITY TABOO</title>
  <style>
    html, body{
      height:100%;
      overflow:hidden;
      overscroll-behavior:none;
    }
    :root{
      --bg:#000;
      --pad:20px;             /* outer padding on all sides */
      --gap:20px;             /* card-to-buttonbar gap */

      --card-radius:38px;
      --card-bg:#fff;
      --card-header-bg:#6f8f2a;

      /* typography scales with viewport width (≈ card width) */
      /* DOUBLED TYPE FOR LOW VISION */
      --fs-amity: clamp(36px, 9.6vw, 68px);
  --fs-games: clamp(18px, 3.8vw, 34px);
      --fs-taboo: clamp(58px, 15.2vw, 150px);
      --fs-tagline: clamp(32px, 7.2vw, 52px);
      --fs-body: clamp(40px, 8.8vw, 68px);
      --fs-just: clamp(46px, 10.4vw, 78px);
      --fs-ready: clamp(32px, 7.2vw, 52px);
      --fs-btn: clamp(48px, 13.2vw, 88px);
      --fs-status: clamp(28px, 6.4vw, 40px);
    }

    *{ box-sizing:border-box; }
    html,body{
      height:100%;
      margin:0;
      background:var(--bg);
      color:#111;
      font-family: system-ui,-apple-system,Segoe UI,Roboto,Inter,Arial,sans-serif;
      -webkit-text-size-adjust:100%;
      text-size-adjust:100%;
    }

    /* Keep the 20px padding, but also respect iOS safe areas. */
    .screen{
      min-height:100vh;
      display:flex;
      flex-direction:column;
      padding:
        calc(var(--pad) + env(safe-area-inset-top))
        calc(var(--pad) + env(safe-area-inset-right))
        calc(var(--pad) + env(safe-area-inset-bottom))
        calc(var(--pad) + env(safe-area-inset-left));
      gap:var(--gap);
    }

    .card{
      width:100%;
      aspect-ratio:5 / 7;
      background:var(--card-bg);
      border-radius:var(--card-radius);
      overflow:hidden;
      display:flex;
      flex-direction:column;
      position:relative;
      border:4px solid #000;
    }

    .under-card{
      position:absolute;
      inset:0;
      z-index:0;
      display:flex;
      flex-direction:column;
      border-radius:calc(var(--card-radius) - 4px);
      overflow:hidden;
      background:#fff;
      pointer-events:none;
    }

        .card-face{
      position:absolute;
      inset:0;
      z-index:2;
      display:flex;
      flex-direction:column;
      transform:translateX(0);
      opacity:1;
      transition:transform 180ms ease, opacity 180ms ease;
      will-change:transform, opacity;
      background:transparent;
      overflow:visible;
      min-height:100%;
    }

    .card-face.is-dragging{
      transition:none;
      }

    .card-face.slide-out-left{
      transform:translateX(-120vw);
      opacity:0;
      }

    .card-face.slide-out-right{
      transform:translateX(120vw);
      opacity:0;
      }

    .card-face.slide-in-left{
      transform:translateX(-18vw);
      opacity:0;
      }

    .card-face.slide-in-right{
      transform:translateX(18vw);
      opacity:0;
      }

    .under-card-top{
      flex:0 0 20%;
      background:var(--card-header-bg);
    }

    .under-card-bottom{
      flex:1 1 auto;
      background:#fff;
    }

    /* Green field = ~20% of card height */
    .header{
      flex:0 0 20%;
      background:var(--card-header-bg);
      display:flex;
      flex-direction:column;
      justify-content:center;
      align-items:center;
      padding:10px 12px;
      position:relative;
      z-index:2;
    }

    /* Constrain AMITY GAMES + underline to the same width as AMITY TABOO */
    .title-block{
      width:fit-content;
      max-width:100%;
      display:flex;
      flex-direction:column;
      align-items:center;
    }

    .amity-games{
  width:auto;
  align-self:stretch;
  display:flex;
  justify-content:space-between;
  align-items:flex-end;
  font-weight:800;
  letter-spacing:0.42em;
  font-size:var(--fs-games);
  color:#fff;
  line-height:1;
  position:relative;
  padding:0;
}

.amity-games .ag-left,
.amity-games .ag-right{
  display:inline-block;
  white-space:nowrap;
}

.amity-games::after{
  content:"";
  position:absolute;
  left:0;
  right:0;
  height:4px;
  background:#fff;
  bottom:0;
}

.amity-taboo{
      font-size:var(--fs-taboo);
      font-family: Impact, Haettenschweiler, "Arial Narrow Bold", sans-serif;
      font-weight:900;
      color:#7b1f1f;
      letter-spacing:0.02em;
      line-height:1;
      margin:0;
      text-transform:uppercase;
      text-align:center;
      white-space:nowrap;
    }

    .content{
      flex:1 1 auto;
      display:flex;
      flex-direction:column;
      justify-content:flex-start;
      align-items:center;
      padding:18px 18px 18px;
      text-align:center;
      min-height:0;
      touch-action:none;
      position:relative;
      z-index:2;
      background:transparent;
    }

    .tagline{
      font-size:var(--fs-tagline);
      font-style:italic;
      font-weight:700;
      margin:10px 0 calc(var(--fs-body) * 1.6) 0;
      opacity:0.9;
    }

    .rules{
      font-size:var(--fs-body);
      font-weight:700;
      line-height:1.25;
      margin:0 0 14px 0;
    }

    .just { font-size: var(--fs-body); font-weight: 700; text-transform: uppercase; margin:0 0 calc(var(--fs-ready) * 1.1) 0;}

    .ready{
      font-size:var(--fs-ready);
      font-weight:650;
      margin:0 0 12px 0;
    }

    .card{
      flex:1 1 auto;
    }


    #deck-status{
      text-align:center;
      width:100%;
      margin-left:auto;
      margin-right:auto;
    }

    .playCard{
      height:100%;
      display:flex;
      flex-direction:column;
    }

    .card-face{
      position:relative;
      z-index:2;
      display:flex;
      flex-direction:column;
      height:100%;
      transform:translateX(0);
      opacity:1;
      transition:transform 180ms ease, opacity 180ms ease, box-shadow 180ms ease;
      will-change:transform, opacity;
      background:transparent;
    }

        .card-face::after{
      content:"";
      position:absolute;
      top:-4px;
      bottom:-4px;
      width:4px;
      background:#000;
      opacity:0;
      pointer-events:none;
      z-index:30;
      left:auto;
      right:0;
      box-shadow:-14px 0 22px rgba(0,0,0,0.42);
    }

    .card-face.is-dragging::after,
    .card-face.drag-left::after,
    .card-face.drag-right::after,
    .card-face.slide-out-left::after,
    .card-face.slide-out-right::after,
    .card-face.slide-in-left::after,
    .card-face.slide-in-right::after{
      opacity:1;
    }

        .card-face.drag-left::after,
    .card-face.slide-out-left::after,
    .card-face.slide-in-left::after{
      right:0;
      left:auto;
      box-shadow:-14px 0 22px rgba(0,0,0,0.42);
    }

        .card-face.drag-right::after,
    .card-face.slide-out-right::after,
    .card-face.slide-in-right::after{
      left:0;
      right:auto;
      box-shadow:14px 0 22px rgba(0,0,0,0.42);
    }

    .card-face.is-dragging{
      transition:none;
      }

    .card-face.slide-out-left{
      transform:translateX(-120vw);
      opacity:0;
      }

    .card-face.slide-out-right{
      transform:translateX(120vw);
      opacity:0;
      }

    .card-face.slide-in-left{
      transform:translateX(-18vw);
      opacity:0;
      }

    .card-face.slide-in-right{
      transform:translateX(18vw);
      opacity:0;
      }

    .playGreen{
      flex:0 0 20%;
      background:transparent;
      display:flex;
      align-items:center;
      justify-content:center;
      padding:12px 16px 0 16px;
    }

    .playWhite{
      flex:1 1 auto;
      background:#fff;
      display:flex;
      flex-direction:column;
      align-items:center;
      justify-content:center;
      gap:24px;
      padding:28px 20px;
    }

    .playTarget{
      width:100%;
      font-size:clamp(64px, 12vw, 124px);
      line-height:1;
      font-weight:900;
      color:var(--card-header-bg);
      text-align:center;
      letter-spacing:0.02em;
      text-transform:uppercase;
    }

    .playTaboo{
      width:100%;
      font-size:clamp(40px, 8vw, 72px);
      line-height:1.05;
      font-weight:900;
      color:#7b1f1f;
      text-align:center;
      text-transform:uppercase;
      letter-spacing:0.02em;
      white-space:pre-line;
    }


    .begin{
      font-size:var(--fs-btn);
      font-weight:900;
      padding:14px 26px;
      border:4px solid #111;
      border-radius:16px;
      background:#fff;
      opacity:1;
      color:#111;
      letter-spacing:0.08em;
      text-transform:uppercase;
      user-select:none;
    }

    .begin.disabled{
      opacity:0.35;
      pointer-events:none;
      color:#111;
    }

    .begin.enabled{
      opacity:1;
      pointer-events:auto;
      color:#000;
    }

    .btn.disabled{
      opacity:0.35;
      pointer-events:none;
    }

    .btn.enabled{
      opacity:1;
      pointer-events:auto;
    }

    .loading-letters{
      display:inline-block;
      white-space:nowrap;
      min-width:18ch;
      text-align:left;
    }

    .sr-only{
      position:absolute !important;
      width:1px !important;
      height:1px !important;
      padding:0 !important;
      margin:-1px !important;
      overflow:hidden !important;
      clip:rect(0,0,0,0) !important;
      white-space:nowrap !important;
      border:0 !important;
    }

    .loading-letters span{
      display:inline-block;
      animation: loadingPulse 1.2s infinite;
    }

    .loading-letters span:nth-child(1){ animation-delay:0ms; }
    .loading-letters span:nth-child(2){ animation-delay:60ms; }
    .loading-letters span:nth-child(3){ animation-delay:120ms; }
    .loading-letters span:nth-child(4){ animation-delay:180ms; }
    .loading-letters span:nth-child(5){ animation-delay:240ms; }
    .loading-letters span:nth-child(6){ animation-delay:300ms; }
    .loading-letters span:nth-child(7){ animation-delay:360ms; }
    .loading-letters span:nth-child(8){ animation-delay:420ms; }
    .loading-letters span:nth-child(9){ animation-delay:480ms; }
    .loading-letters span:nth-child(10){ animation-delay:540ms; }
    .loading-letters span:nth-child(11){ animation-delay:600ms; }

    @keyframes loadingPulse{
      0%{ transform:translateY(0); opacity:0.45; }
      40%{ transform:translateY(-2px); opacity:1; }
      100%{ transform:translateY(0); opacity:0.45; }
    }


    .buttonbar{
      display:flex;
      gap:16px;
      align-items:stretch;
      width:100%;
      flex:0 0 auto;
      height:min(clamp(84px, 16vh, 260px), calc((100% - 16px)/2));
    }

    .btn{
      flex:1 1 0;
      background:var(--card-header-bg);
      border:4px solid #222;
      border-radius:var(--btn-radius,18px);
      height:100%;
      display:flex;
      align-items:center;
      justify-content:center;
      padding:0;
      font-size:var(--fs-btn);
      font-weight:900;
      text-transform:uppercase;
      text-align:center;
      color:#000;
      user-select:none;
      line-height:1;
    }

        .swipe-hint{
      margin-top:16px;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-height:64px;
      padding:12px 22px;
      border:4px solid #000;
      border-radius:999px;
      background:var(--card-header-bg);
      color:#000;
      font-size:var(--fs-body);
      line-height:1.05;
      text-align:center;
      opacity:1;
      letter-spacing:.02em;
      font-weight:900;
      text-transform:uppercase;
      white-space:nowrap;
      touch-action:none;
      user-select:none;
    }

        .shuffle-hint{
      margin-top:auto;
      padding-top:72px;
      padding-bottom:220px;
      font-size:var(--fs-ready);
      line-height:1.1;
      text-align:center;
      font-weight:650;
      opacity:1;
      touch-action:none;
      user-select:none;
    }

    .shuffle-sub{
      font-size:clamp(16px, 3.8vw, 22px);
      font-weight:700;
      opacity:.9;
    }

    .buttonbar{
      display:none !important;
    }

    #btn-begin{
      display:none !important;
    }

    .statusbar{
      width:100%;
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:12px;
      font-size:var(--fs-status);
      color:#fff;
      padding:10px 0 0;
    }

    .status-mid{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-height:56px;
      padding:8px 18px;
      border:3px solid #000;
      border-radius:999px;
      background:#ED7437;
      color:#000;
      font-size:24px;
      font-weight:900;
      line-height:1;
      text-decoration:none;
      white-space:nowrap;
      flex:0 0 auto;
    }

    /* Keep the card from getting absurdly tall on short screens */
    @media (max-height: 700px){
      :root{ --gap:14px; }
      .content{ padding:18px 14px 14px; }
      .begin{ padding:12px 22px; }
      .btn{ padding:14px 8px; }
    }
  .just-prompts{font-size: var(--fs-body); font-weight: 700;}
.taboo-words-label{display:none;}
</style>
</head>
<body>
  <div class="screen">
    <div class="card">
      <div class="under-card" aria-hidden="true">
        <div class="under-card-top"></div>
        <div class="under-card-bottom"></div>
      </div>

      <div class="card-face">
        <div class="header">
          <div class="title-block">
            <div class="amity-games" aria-label="Amity Games"><span class="ag-left">AMITY</span><span class="ag-right">GAMES</span></div>
            <div class="amity-taboo">AMITY TABOO</div>
          </div>
        </div>

        <div class="content">
          <div class="tagline">(a friendly game of taboo)</div>
          <div class="rules">No teams.<br>No timers.<br>No scores.</div>
          <div class="just"><span class="just-prompts">JUST PROMPTS.</span></div>
          <div class="ready" id="deck-status">Your deck is ready.</div>
          <div class="swipe-hint" id="swipe-hint" aria-hidden="true">&larr; Swipe to play &rarr;</div>
          <div class="shuffle-hint" id="shuffle-hint" aria-hidden="true">Double tap to shuffle</div>
          <button type="button" class="begin disabled" id="btn-begin" aria-disabled="true" disabled>BEGIN PLAY</button>
        </div>
      </div>
    </div>

    <div class="buttonbar">
      <button type="button" class="btn disabled" id="btn-back" aria-disabled="true" disabled>◀ BACK</button>
      <button type="button" class="btn disabled" id="btn-next" aria-disabled="true" disabled>NEXT ▶</button>
    </div>

    <div class="statusbar" aria-hidden="true">
      <div class="status-left" id="status-deck">Deck: 0</div>
      <a class="status-mid" href="https://buymeacoffee.com/scaryhouse" target="_blank" rel="noopener noreferrer" aria-label="Buy me a Coffee">Buy me a Coffee</a>
      <div class="status-right" id="status-cardid">Card ID: #0000</div>
    </div>

    <div id="sr-live" aria-live="polite" aria-atomic="true" style="position:absolute;left:-9999px;top:auto;width:1px;height:1px;overflow:hidden;"></div>
  </div>

<script>
  (function(){
    function _fitButtonBar(){
      const screen = document.querySelector('.screen');
      const card = document.querySelector('.card');
      const bar = document.querySelector('.buttonbar');
      const status = document.querySelector('.statusbar');
      if(!screen || !card || !bar || !status) return;

      // Reset to natural sizing so measurements are accurate
      bar.style.height = '';

      const gap = parseFloat(getComputedStyle(screen).gap || '0') || 0;
      const total = screen.clientHeight;
      const used = card.offsetHeight + status.offsetHeight + (2 * gap);
      const free = Math.max(0, total - used);

      const barGap = parseFloat(getComputedStyle(bar).gap || '0') || 0;
      const btnWidth = Math.max(0, (bar.clientWidth - barGap) / 2);

      const minH = 72; // avoid disappearing controls
      const targetH = Math.max(minH, Math.min(free, btnWidth));

      bar.style.height = Math.floor(targetH) + 'px';

      // Keep corner radius proportional to height
      const r = Math.max(14, Math.min(22, targetH * 0.28));
      document.documentElement.style.setProperty('--btn-radius', Math.floor(r) + 'px');
    }

    window.addEventListener('resize', _fitButtonBar, {passive:true});
    window.addEventListener('orientationchange', _fitButtonBar, {passive:true});
    window.addEventListener('load', _fitButtonBar, {passive:true});
    // After fonts/layout settle
    setTimeout(_fitButtonBar, 0);
    setTimeout(_fitButtonBar, 250);

    // ==================================================
    // GAMEPLAY / STATE (Milestone 1)
    // ==================================================

    const LS_KEY = 'amity_taboo_deck_v1';

    const elDeckStatus = document.getElementById('deck-status');
    const elBegin = document.getElementById('btn-begin');
    const elBack = document.getElementById('btn-back');
    const elNext = document.getElementById('btn-next');
    const elStatusDeck = document.getElementById('status-deck');
    const elStatusCard = document.getElementById('status-cardid');
    const elSr = document.getElementById('sr-live');









    function setBackEnabled(on){
      setEnabled(elBack, !!on);
    }

    function setNextEnabled(on){
      setEnabled(elNext, !!on);
    }

    // Back-compat shim. Older revisions called setNavEnabled(true/false).
    // Newer flow can call setNavEnabled(backOn, nextOn).
    function setNavEnabled(a, b){
      if (arguments.length === 2){
        setBackEnabled(a);
        setNextEnabled(b);
        return;
      }
      if (typeof a === 'boolean'){
        setBackEnabled(a);
        setNextEnabled(a);
      }
    }









    let audioCtx_ = null;

    function getAudioContext_(){
      try{
        const AC = window.AudioContext || window.webkitAudioContext;
        if(!AC) return null;
        if(!audioCtx_) audioCtx_ = new AC();
        if(audioCtx_.state === 'suspended'){
          audioCtx_.resume().catch(function(){});
        }
        return audioCtx_;
      }catch(e){
        return null;
      }
    }

    function playTone_(freq, startAt, duration, gainValue, type){
      const ctx = getAudioContext_();
      if(!ctx) return null;

      const osc = ctx.createOscillator();
      const gain = ctx.createGain();

      osc.type = type || 'triangle';
      osc.frequency.setValueAtTime(freq, startAt);

      gain.gain.setValueAtTime(0.0001, startAt);
      gain.gain.exponentialRampToValueAtTime(gainValue, startAt + 0.01);
      gain.gain.exponentialRampToValueAtTime(0.0001, startAt + duration);

      osc.connect(gain);
      gain.connect(ctx.destination);

      osc.start(startAt);
      osc.stop(startAt + duration + 0.02);

      return { osc: osc, gain: gain };
    }

    function playDealSound_(){
      const ctx = getAudioContext_();
      if(!ctx) return;
      if(ctx.state === 'suspended'){
        ctx.resume().catch(function(){});
      }

      const dur = 0.09;
      const bufferSize = Math.max(1, Math.floor(ctx.sampleRate * dur));
      const buffer = ctx.createBuffer(1, bufferSize, ctx.sampleRate);
      const data = buffer.getChannelData(0);

      for(let i = 0; i < bufferSize; i++){
        const t = i / bufferSize;
        const env = Math.pow(1 - t, 2.2);
        data[i] = (Math.random() * 2 - 1) * env * 0.38;
      }

      const source = ctx.createBufferSource();
      const highpass = ctx.createBiquadFilter();
      const lowpass = ctx.createBiquadFilter();
      const gain = ctx.createGain();

      highpass.type = 'highpass';
      highpass.frequency.setValueAtTime(700, ctx.currentTime);

      lowpass.type = 'lowpass';
      lowpass.frequency.setValueAtTime(2800, ctx.currentTime);

      gain.gain.setValueAtTime(0.0001, ctx.currentTime);
      gain.gain.exponentialRampToValueAtTime(0.11, ctx.currentTime + 0.006);
      gain.gain.exponentialRampToValueAtTime(0.0001, ctx.currentTime + dur);

      source.buffer = buffer;
      source.connect(highpass);
      highpass.connect(lowpass);
      lowpass.connect(gain);
      gain.connect(ctx.destination);

      source.start();
    }

    function playShuffleSound_(){
      const ctx = getAudioContext_();
      if(!ctx) return;

      const bufferSize = Math.max(1, Math.floor(ctx.sampleRate * 0.16));
      const buffer = ctx.createBuffer(1, bufferSize, ctx.sampleRate);
      const data = buffer.getChannelData(0);

      for(let i = 0; i < bufferSize; i++){
        const env = 1 - (i / bufferSize);
        data[i] = (Math.random() * 2 - 1) * env * 0.45;
      }

      const source = ctx.createBufferSource();
      const filter = ctx.createBiquadFilter();
      const gain = ctx.createGain();

      filter.type = 'bandpass';
      filter.frequency.setValueAtTime(1400, ctx.currentTime);
      filter.Q.setValueAtTime(0.8, ctx.currentTime);

      gain.gain.setValueAtTime(0.0001, ctx.currentTime);
      gain.gain.exponentialRampToValueAtTime(0.06, ctx.currentTime + 0.01);
      gain.gain.exponentialRampToValueAtTime(0.0001, ctx.currentTime + 0.18);

      source.buffer = buffer;
      source.connect(filter);
      filter.connect(gain);
      gain.connect(ctx.destination);
      source.start();
    }

    function primeAudio_(){
      getAudioContext_();
    }

    function srSay(msg){
      if(!elSr) return;
      elSr.textContent = '';
      // Small delay improves reliability in some SR/browser combos
      setTimeout(function(){ elSr.textContent = msg; }, 30);
    }

    function setEnabled(el, on){
      if(!el) return;
      if(on){
        el.classList.remove('disabled');
        el.classList.add('enabled');
        el.setAttribute('aria-disabled','false');
        if('disabled' in el) el.disabled = false;
      }else{
        el.classList.add('disabled');
        el.classList.remove('enabled');
        el.setAttribute('aria-disabled','true');
        if('disabled' in el) el.disabled = true;
      }
    }

    function setInstructionLoading(){
      // Visual progressive Loading... + disable controls
      if(elDeckStatus){
        // single span we can update
        elDeckStatus.innerHTML = '<span class="loading-letters" aria-hidden="true"></span>';
      }
      setEnabled(elBegin, false);
      setEnabled(elNext, false);
      setEnabled(elBack, false);

      const el = elDeckStatus ? elDeckStatus.querySelector('.loading-letters') : null;
      if(!el) return;

      const letters = "Loading...";
      let i = 0;
      el.textContent = "";

      if(window._loadingTimer) clearInterval(window._loadingTimer);
      window._loadingTimer = setInterval(function(){
        if(i < letters.length){
          el.textContent = letters.slice(0, i+1);
          i++;
        }else{
          el.textContent = "";
          i = 0;
        }
      }, 250);
    }

    function setInstructionReady(total){
      if(elDeckStatus) elDeckStatus.textContent = 'Your deck is ready.';
      if(elStatusDeck) elStatusDeck.textContent = 'Deck: ' + String(total || 0);
      if(elStatusCard) elStatusCard.textContent = 'Card ID: #0000';

      setEnabled(elBegin, true);
      setEnabled(elNext, true);
      setEnabled(elBack, false);

      playShuffleSound_();
      srSay('Amity Taboo. A friendly game of taboo. No teams. No timers. No scores. Just prompts. Your deck is ready. Swipe left or right to play.');
    }

    function showInstructionCard(){
      // Restore instruction layout (keep current title/header)
      if(elDeckStatus) elDeckStatus.textContent = '';
      const targetEl = document.querySelector('.target');
      const tabooEl = document.querySelector('.taboo');
      if(targetEl) targetEl.textContent = '';
      if(tabooEl) tabooEl.textContent = '';
      // Buttons will be set by loading/ready calls
    }

    let motionPermissionRequested_ = false;
    let shakeEnabled_ = false;
    let shakeState_ = {
      lastMagnitude: 0,
      lastShakeAt: 0
    };

    function requestMotionPermissionIfNeeded_(){
      try{
        if(typeof window === 'undefined') return;
        const DM = window.DeviceMotionEvent;
        if(!DM){
          shakeEnabled_ = true;
          return;
        }
        if(typeof DM.requestPermission !== 'function'){
          shakeEnabled_ = true;
          return;
        }
        if(motionPermissionRequested_) return;
        motionPermissionRequested_ = true;
        DM.requestPermission()
          .then(function(state){
            shakeEnabled_ = (state === 'granted');
          })
          .catch(function(){
            shakeEnabled_ = false;
          });
      }catch(e){
        shakeEnabled_ = false;
      }
    }

    function triggerShuffle_(){
      const now = Date.now();
      if(now - shakeState_.lastShakeAt < 2500) return;
      shakeState_.lastShakeAt = now;
      srSay('Shuffling. Building a new deck.');
      startBuildNewDeck();
    }

    function bindDoubleTapShuffle_(){
      const surface = document.querySelector('.card') || document.querySelector('.content') || document.body;
      if(!surface) return;

      let lastTapAt = 0;

      surface.addEventListener('click', function(e){
        if(e && e.target && e.target.closest && e.target.closest('a')) return;
        const now = Date.now();
        if(now - lastTapAt <= 350){
          triggerShuffle_();
          lastTapAt = 0;
          return;
        }
        lastTapAt = now;
      });
    }

    function bindShakeToShuffle_(){
      if(typeof window === 'undefined') return;

      window.addEventListener('devicemotion', function(e){
        if(!shakeEnabled_) return;
        const a = e && e.accelerationIncludingGravity;
        if(!a) return;

        const x = Number(a.x || 0);
        const y = Number(a.y || 0);
        const z = Number(a.z || 0);
        const magnitude = Math.sqrt((x * x) + (y * y) + (z * z));
        const delta = Math.abs(magnitude - shakeState_.lastMagnitude);
        shakeState_.lastMagnitude = magnitude;

        if(delta > 18){
          triggerShuffle_();
        }
      }, { passive: true });
    }


    function saveSession(session){
      try{
        localStorage.setItem(LS_KEY, JSON.stringify(session));
      }catch(e){}
    }

    function loadSession(){
      try{
        const raw = localStorage.getItem(LS_KEY);
        if(!raw) return null;
        const obj = JSON.parse(raw);
        if(!obj || !Array.isArray(obj.cards) || !obj.cards.length) return null;
        if(typeof obj.index !== 'number') obj.index = 0;
        return obj;
      }catch(e){
        return null;
      }
    }

    function clearSession(){
      try{ localStorage.removeItem(LS_KEY); }catch(e){}
    }
    function startBuildNewDeck(){
      clearSession();
      setInstructionLoading();
      google.script.run
        .withSuccessHandler(function(res){
          const cards = (res && res.cards) ? res.cards : [];
          const total = (res && res.total) ? res.total : cards.length;
          const session = {
            schema: 1,
            deckId: (res && res.deckId) ? res.deckId : String(Date.now()),
            index: 0,
            total: total,
            cards: cards
          };
          saveSession(session);
          if(window._loadingTimer) clearInterval(window._loadingTimer);
          setInstructionReady(total);
        })
        .withFailureHandler(function(err){
          if(elDeckStatus) elDeckStatus.textContent = 'Unable to build deck.';
          setEnabled(elBegin, false);
          setEnabled(elBack, false);
          setEnabled(elNext, false);
        })
        .buildDeck();
    }


    function getDeckDisplayNumber_(s, idx){
  const total = Number(s && s.total) || 0;
  const current = Math.max(0, Math.min(Number(idx) || 0, Math.max(0, total - 1)));
  if(!total) return 0;
  return current + 1;
}

function getDeckStatusText_(s, idx){
  const total = Number(s && s.total) || 0;
  if(!total) return 'Deck: 0';
  if(!s || s.mode !== 'PLAY') return `Deck: ${total}`;
  return `Deck: ${getDeckDisplayNumber_(s, idx)} of ${total}`;
}

function getAnimatedCard_(){
  return document.querySelector('.card-face');
}

function setSwipeDragOffset_(dx){
  const card = getAnimatedCard_();
  if(!card) return;
  card.classList.add('is-dragging');
  card.classList.remove('drag-left', 'drag-right');
  card.classList.add(dx < 0 ? 'drag-left' : 'drag-right');
  card.style.transform = `translateX(${dx}px)`;
  card.style.opacity = String(Math.max(0.72, 1 - Math.min(Math.abs(dx) / 500, 0.28)));
}

function clearSwipeDrag_(){
  const card = getAnimatedCard_();
  if(!card) return;
  card.classList.remove('is-dragging', 'drag-left', 'drag-right', 'slide-out-left', 'slide-out-right', 'slide-in-left', 'slide-in-right');
  card.style.transform = '';
  card.style.opacity = '';
  card.style.boxShadow = '';
}

function animateSwipeTransition_(dir, callback){
  const card = getAnimatedCard_();
  if(!card){
    callback();
    return;
  }

  let done = false;

  function finish(){
    if(done) return;
    done = true;
    card.removeEventListener('transitionend', finish);
    callback();
  }

  const currentTransform = getComputedStyle(card).transform;
  const currentOpacity = getComputedStyle(card).opacity;

  card.classList.remove('slide-in-left', 'slide-in-right', 'slide-out-left', 'slide-out-right');
  card.classList.remove('is-dragging', 'drag-left', 'drag-right');

  card.style.transform = currentTransform === 'none' ? 'translateX(0px)' : currentTransform;
  card.style.opacity = currentOpacity || '1';

  void card.offsetWidth;

  card.style.transition = 'transform 180ms ease, opacity 180ms ease, box-shadow 180ms ease';
  card.style.transform = dir === 'left' ? 'translateX(-120vw)' : 'translateX(120vw)';
  card.style.opacity = '0';

  card.addEventListener('transitionend', finish, { once: true });
  setTimeout(finish, 220);
}

    function renderCard(i){
  const s = loadSession();
  if(!s || !Array.isArray(s.cards) || s.cards.length === 0){
    showInstructionCard();
    return;
  }

  const idx = Math.max(0, Math.min(Number(i)||0, s.cards.length-1));
  s.index = idx;
  saveSession(s);

  const card = s.cards[idx];
  const elContent = document.querySelector('.content');
  if(!elContent || !card){
    return;
  }

  const esc = (v)=>String(v??'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');

  const tabooLines = Array.isArray(card.taboo) ? card.taboo : [];

  const targetText = String(card.target ?? '').trim();
  const targetUpper = targetText.toUpperCase();

  elContent.innerHTML = `
    <div class="playCard">
      <div class="playGreen" aria-hidden="true">
        <div class="playTarget">${esc(targetUpper)}</div>
      </div>
      <div class="playWhite" aria-hidden="true">
        ${tabooLines.map(w=>`<div class="playTaboo">${esc(String(w).toUpperCase())}</div>`).join('')}
      </div>
      
    </div>
  `;

  const animatedCardEl = getAnimatedCard_();
  const incomingDir = String(window.__amityIncomingDir || '');
  if(animatedCardEl && incomingDir){
    animatedCardEl.classList.remove('slide-out-left', 'slide-out-right', 'is-dragging', 'drag-left', 'drag-right');
    animatedCardEl.style.transform = '';
    animatedCardEl.style.opacity = '';
    animatedCardEl.classList.add(incomingDir === 'left' ? 'slide-in-left' : 'slide-in-right');
    requestAnimationFrame(function(){
      requestAnimationFrame(function(){
        animatedCardEl.classList.remove('slide-in-left', 'slide-in-right');
      });
    });
    window.__amityIncomingDir = '';
  }

  // Status
  if(elStatusDeck){
    elStatusDeck.textContent = getDeckStatusText_(s, idx);
  }
  if(elStatusCard){
    const n = Number(card.rowId)||0;
    elStatusCard.textContent = n ? `Card #${n}` : '';
  }

  // Buttons
  setBackEnabled(idx > 0);
  setNextEnabled(idx < (s.total-1));

  const spokenTaboo = tabooLines.map(w=>String(w).trim()).filter(Boolean).join(', ');
  const spokenDeck = getDeckDisplayNumber_(s, idx);
  const spokenPrefix = (idx === (s.total - 1))
    ? `Final card. Deck ${spokenDeck} of ${s.total}. `
    : `Deck ${spokenDeck} of ${s.total}. `;
  const spoken = spokenTaboo
    ? `${spokenPrefix}Target word: ${targetText}. Taboo words: ${spokenTaboo}.`
    : `${spokenPrefix}Target word: ${targetText}.`;
  window.setTimeout(()=>{ srSay(spoken); }, 50);
}

function onBeginPlay(direction){
  requestMotionPermissionIfNeeded_();
  const s = loadSession();
  if(!s || !Array.isArray(s.cards) || s.cards.length===0) return;
  s.index = (direction === 'back') ? (s.cards.length - 1) : 0;
  s.mode = 'PLAY';
  saveSession(s);
  renderCard(s.index);
  
}

    function onNext(){
      const s = loadSession();
      if(!s || !Array.isArray(s.cards) || s.cards.length===0) return;

      if(s.mode !== 'PLAY'){
        onBeginPlay('forward');
        return;
      }

      const nextIndex = (typeof s.index === 'number' ? s.index : 0) + 1;

      if(nextIndex >= s.cards.length){
        s.mode = 'INSTRUCTION';
        s.index = 0;
        saveSession(s);
        showInstructionCard();
        startBuildNewDeck();
        return;
      }

      s.index = nextIndex;
      saveSession(s);
      renderCard(s.index);
    }

    function onBack(){
      const s = loadSession();
      if(!s || !Array.isArray(s.cards) || s.cards.length===0) return;

      if(s.mode !== 'PLAY'){
        onBeginPlay('back');
        return;
      }

      const prevIndex = (typeof s.index === 'number' ? s.index : 0) - 1;
      if(prevIndex < 0){
        s.index = s.cards.length - 1;
        saveSession(s);
        renderCard(s.index);
        return;
      }

      s.index = prevIndex;
      saveSession(s);
      renderCard(s.index);
    }



    function bindClick(el, fn){
      if(!el) return;
      el.addEventListener('click', function(){
        if(el.getAttribute('aria-disabled') === 'true' || el.disabled) return;
        fn();
      });
      if(el.tagName === 'BUTTON') return;
      el.addEventListener('keydown', function(e){
        if(el.getAttribute('aria-disabled') === 'true') return;
        if(e.key === 'Enter' || e.key === ' '){
          e.preventDefault();
          fn();
        }
      });
    }

    bindClick(elBegin, onBeginPlay);
    bindClick(elNext, onNext);
    bindClick(elBack, onBack);

    function bindSwipeNavigation(){
      const root = document;
      if(!root) return;

      const thresholdX = 95;
      const maxOffAxisY = 80;
      let startX = null;
      let startY = null;
      let lastX = null;
      let lastY = null;
      let tracking = false;

      function reset(){
        startX = null;
        startY = null;
        lastX = null;
        lastY = null;
        tracking = false;
      }

      function shouldIgnoreTarget(target){
        return !!(target && target.closest && target.closest('a'));
      }

      function begin(x, y, target){
        if(shouldIgnoreTarget(target)) return;
        startX = Number(x);
        startY = Number(y);
        lastX = Number(x);
        lastY = Number(y);
        tracking = true;
      }

      function move(x, y, ev){
        if(!tracking) return;
        lastX = Number(x);
        lastY = Number(y);

        const dx = lastX - startX;
        const dy = lastY - startY;

        if(Math.abs(dx) > 34 && Math.abs(dx) > Math.abs(dy)){
          setSwipeDragOffset_(dx);
          if(ev && typeof ev.preventDefault === 'function'){
            ev.preventDefault();
          }
        }
      }

      function finish(x, y){
        if(!tracking){
          clearSwipeDrag_();
          reset();
          return;
        }

        if(typeof x === 'number') lastX = Number(x);
        if(typeof y === 'number') lastY = Number(y);

        const dx = Number(lastX) - Number(startX);
        const dy = Number(lastY) - Number(startY);
        const shouldFire = Math.abs(dx) >= thresholdX && Math.abs(dx) > (Math.abs(dy) * 1.6) && !(Math.abs(dy) > maxOffAxisY && Math.abs(dy) > Math.abs(dx));

        if(!shouldFire){
          clearSwipeDrag_();
          reset();
          return;
        }

        const direction = dx < 0 ? 'left' : 'right';
        reset();

        playDealSound_();

        animateSwipeTransition_(direction, function(){
          const s = loadSession();

          if(!s || s.mode !== 'PLAY'){
            window.__amityIncomingDir = direction === 'left' ? 'right' : 'left';
            onBeginPlay(direction === 'left' ? 'forward' : 'back');
            return;
          }

          window.__amityIncomingDir = direction === 'left' ? 'right' : 'left';

          if(direction === 'left'){
            onNext();
          } else {
            onBack();
          }
        });
      }

      root.addEventListener('touchstart', function(e){
        const t = e.changedTouches && e.changedTouches[0];
        if(!t) return;
        begin(t.clientX, t.clientY, e.target);
      }, { passive: true, capture: true });

      root.addEventListener('touchmove', function(e){
        const t = e.changedTouches && e.changedTouches[0];
        if(!t) return;
        move(t.clientX, t.clientY, e);
      }, { passive: false, capture: true });

      root.addEventListener('touchend', function(e){
        const t = e.changedTouches && e.changedTouches[0];
        if(!t){
          finish(lastX, lastY);
          return;
        }
        finish(t.clientX, t.clientY);
      }, { passive: true, capture: true });

      root.addEventListener('touchcancel', function(){
        clearSwipeDrag_();
        reset();
      }, { passive: true, capture: true });
    }

    bindSwipeNavigation();
    bindShakeToShuffle_();
    bindDoubleTapShuffle_();

    document.addEventListener('touchstart', primeAudio_, { passive: true, once: true, capture: true });
    document.addEventListener('click', primeAudio_, { passive: true, once: true, capture: true });

    // Bootstrap:
    clearSession();
      startBuildNewDeck();

      window.__amity = { loadSession: loadSession, saveSession: saveSession, clearSession: clearSession };

})();
</script>

